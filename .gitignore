# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Generated / temp files (DO NOT commit videos or frame dumps) ──────────────
temp/*
!temp/.gitkeep
output/*
!output/.gitkeep

# ── OS junk ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ── Claude internal ───────────────────────────────────────────────────────────
.claude/
